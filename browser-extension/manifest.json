{
  "manifest_version": 3,
  "name": "Productivity Challenge — Time Tracker",
  "version": "1.0.0",
  "description": "Reports the active tab URL to the local Productivity Challenge tracker for automatic category detection.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "activeTab"],
  "host_permissions": ["http://localhost:27183/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Productivity Challenge Time Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
